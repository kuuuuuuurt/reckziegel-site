---
import { getCollection, render } from 'astro:content';
import WorkDetail from '../../layouts/WorkDetail.astro';

export async function getStaticPaths() {
  const work = (await getCollection('work')).sort(
    (a, b) => a.data.order - b.data.order,
  );

  return work.map((entry, i) => {
    const prev = work[i - 1];
    const next = work[i + 1];
    return {
      params: { slug: entry.id },
      props: {
        entry,
        prev: prev ? { slug: prev.id, title: prev.data.title } : null,
        next: next ? { slug: next.id, title: next.data.title } : null,
      },
    };
  });
}

const { entry, prev, next } = Astro.props;
const { Content } = await render(entry);
---
<WorkDetail
  title={entry.data.title}
  client={entry.data.client}
  timeframe={entry.data.timeframe}
  summary={entry.data.summary}
  prev={prev}
  next={next}
>
  <Content />
</WorkDetail>
