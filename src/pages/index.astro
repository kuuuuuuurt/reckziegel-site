---
import Base from '../layouts/Base.astro';
import Logo from '../components/Logo.astro';
import Icon from '../components/Icon.astro';
import { getCollection } from 'astro:content';
import { parseBio } from '../lib/parseBio';
import { publications } from '../data/publications';
import bioRaw from '../content/bio.md?raw';

const { data: bio, paragraphs } = parseBio(bioRaw);

const work = (await getCollection('work')).sort(
  (a, b) => a.data.order - b.data.order,
);
---
<Base
  title={`${bio.name} — Strategy, Research & Brand Consultant`}
  description={bio.tagline}
>
  <main class="home">
    <div class="main-col">
      <header class="intro">
        <div class="intro-identity">
          <img
            src="/headshot.jpg"
            alt={`Headshot of ${bio.name}`}
            class="headshot"
            width="108"
            height="108"
          />
          <div class="intro-name">
            <h1>{bio.name}</h1>
            <p class="pronounced">
              {bio.pronounced}
              <button
                class="pronounce-btn"
                type="button"
                aria-label="Hear pronunciation"
                data-speak="Reck zee guhl"
              >
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
                  <path d="M15.54 8.46a5 5 0 0 1 0 7.07"></path>
                  <path d="M19.07 4.93a10 10 0 0 1 0 14.14"></path>
                </svg>
              </button>
            </p>
          </div>
        </div>

        <p class="tagline">
          <span class="tagline-line">
            <span class="scribbled-question">
              Curious
              <svg class="scribble scribble-q" viewBox="0 0 16 22" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
                <path
                  d="M 3 6 Q 3 1 8 1 Q 14 1.5 12 7 Q 9 9 8.5 13"
                  pathLength="100"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
                <circle cx="8.5" cy="18" r="1.3" fill="currentColor" opacity="0" />
              </svg>
            </span> about people.
          </span>
          <span class="tagline-line">
            Obsessed with <span class="circled">
              brands
              <svg class="scribble scribble-circle" viewBox="0 0 200 100" preserveAspectRatio="none" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
                <!-- Rounded-rectangle-ish oval, tightened so the corners
                     reach out without bleeding into the lines above/beside. -->
                <path
                  d="M 100 4 Q 172 4 198 18 Q 212 34 212 50 Q 212 66 198 82 Q 172 96 100 96 Q 28 96 2 82 Q -12 66 -12 50 Q -12 34 2 18 Q 28 4 100 4 Z"
                  pathLength="100"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="3"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
                <!-- Second pass: same shape rotated ~6° around center, so
                     the two paths cross at upper-left and lower-right
                     instead of nesting like concentric circles. -->
                <path
                  d="M 100 4 Q 172 4 198 18 Q 212 34 212 50 Q 212 66 198 82 Q 172 96 100 96 Q 28 96 2 82 Q -12 66 -12 50 Q -12 34 2 18 Q 28 4 100 4 Z"
                  pathLength="100"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.4"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  opacity="0.85"
                  transform="rotate(-6 100 50)"
                />
              </svg>
            </span>.
          </span>
          <span class="tagline-line tagline-line--underlined">
            Grounded in strategy.
            <svg class="scribble scribble-underline" viewBox="0 0 200 14" preserveAspectRatio="none" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
              <path
                d="M 2 4 Q 30 0, 60 4 T 120 5 T 180 4 T 198 5"
                pathLength="100"
                fill="none"
                stroke="currentColor"
                stroke-width="2.2"
                stroke-linecap="round"
              />
              <path
                d="M 4 11 Q 32 7, 64 11 T 124 10 T 184 11 T 196 10"
                pathLength="100"
                fill="none"
                stroke="currentColor"
                stroke-width="1.7"
                stroke-linecap="round"
                opacity="0.85"
              />
            </svg>
          </span>
        </p>
      </header>

      <section class="bio">
        {
          paragraphs.map((paragraph) => (
            <p>
              {paragraph.map((part) => {
                if (part.type === 'text') return part.value;
                if (part.type === 'flag') {
                  return (
                    <span class="hover-flag" data-flag={part.emoji}>
                      {part.text}
                    </span>
                  );
                }
                if (part.type === 'slash') {
                  return (
                    <svg
                      class="scribble-slash"
                      viewBox="0 0 14 22"
                      aria-hidden="true"
                      xmlns="http://www.w3.org/2000/svg"
                    >
                      <path
                        d="M 11 3 Q 9 6 7 11 Q 5 16 3 20"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.6"
                        stroke-linecap="round"
                      />
                    </svg>
                  );
                }
                return <Logo name={part.slug} />;
              })}
            </p>
          ))
        }
      </section>

      <section class="contact" aria-label="Contact">
        <button
          type="button"
          class="contact-link contact-link--copy"
          data-copy={bio.email}
          aria-label={`Copy email address ${bio.email}`}
        >
          <Icon name="gmail" />
          <span class="contact-label">{bio.email}</span>
          <span class="contact-hint" aria-hidden="true">click to copy</span>
          <span class="contact-flash" aria-hidden="true">Copied!</span>
        </button>
      </section>
    </div>

    <div class="big-screen-egg" aria-hidden="true">
      <span class="big-screen-egg-face">(⌐■_■)</span>
      <span class="big-screen-egg-text">
        whoa, nice<br />
        big screen,<br />
        friend.
      </span>
    </div>

    <aside class="right-col">
      <section class="card-list" aria-labelledby="work-heading">
        <h2 id="work-heading" class="card-list-heading">Selected Work</h2>
        <ul>
          {
            work.map((entry) => (
              <li>
                <a href={`/work/${entry.id}/`}>
                  <span class="card-title">{entry.data.title}</span>
                  <span class="card-arrow" aria-hidden="true">→</span>
                </a>
              </li>
            ))
          }
        </ul>
      </section>

      <section class="card-list" aria-labelledby="publications-heading">
        <h2 id="publications-heading" class="card-list-heading">Publications</h2>
        <ul>
          {
            publications.map((pub) => (
              <li>
                <a href={pub.url} target="_blank" rel="noopener noreferrer">
                  <span class="card-info">
                    <span class="card-title">{pub.title}</span>
                    <span class="card-meta">{pub.venue}</span>
                  </span>
                  <span class="card-arrow" aria-hidden="true">→</span>
                </a>
              </li>
            ))
          }
        </ul>
      </section>
    </aside>
  </main>

  <script>
    // Click the speaker icon next to "Pronounced ..." to hear the name aloud
    // via the Web Speech API. Falls back silently if the browser doesn't
    // support it. Reads the phonetic from data-speak so it sounds right.
    document.querySelectorAll<HTMLButtonElement>('[data-speak]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const phrase = btn.dataset.speak;
        if (!phrase || !('speechSynthesis' in window)) return;
        const u = new SpeechSynthesisUtterance(phrase);
        u.rate = 0.85;
        u.pitch = 1;
        speechSynthesis.cancel();
        speechSynthesis.speak(u);
      });
    });

    // Click the headshot for a 360° spin. Toggle the class so it
    // restarts on each click; clean up when the animation finishes.
    const headshot = document.querySelector<HTMLElement>('.headshot');
    if (headshot) {
      headshot.addEventListener('click', () => {
        headshot.classList.remove('spinning');
        void headshot.offsetWidth; // force reflow so the animation restarts
        headshot.classList.add('spinning');
      });
      headshot.addEventListener('animationend', (e) => {
        if (e.animationName === 'headshot-spin') {
          headshot.classList.remove('spinning');
        }
      });
    }
    // (click-to-copy lives in Base.astro so it works on any page that
    // adds a data-copy element.)
  </script>
</Base>
